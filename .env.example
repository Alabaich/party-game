# ============================================================
#  Скопіюй у .env та заповни. .env У .gitignore — не комітиться.
# ============================================================

# --- Домен гри ---
# Субдомен, який ти створиш у GoDaddy (див. README, розділ DNS).
# Приклад: party.enjob.ca   (без https://, без слешів)
GAME_DOMAIN=party.example.com

# --- Порти на хості (біндяться у 127.0.0.1, за ними стоїть Caddy) ---
# Перевірені вільними на твоєму сервері. Міняй лише якщо зайняв чимось іншим.
BACKEND_PORT=8090
FRONTEND_PORT=8091

# --- CORS ---
# Має збігатися з доменом гри (з https://). Зазвичай: https://${GAME_DOMAIN}
CORS_ORIGINS=https://party.example.com

# --- Postgres (всередині docker-мережі, назовні не виставляється) ---
POSTGRES_USER=party
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=partygame

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=party-media
# Публічний URL бакета (Public Access r2.dev або кастомний домен).
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
